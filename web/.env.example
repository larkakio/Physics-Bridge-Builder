# Site
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Chain (Base mainnet)
NEXT_PUBLIC_CHAIN_ID=8453

# Deployed CheckIn.sol on Base (your deployed address)
NEXT_PUBLIC_CHECK_IN_CONTRACT_ADDRESS=0xF103a95E8bA8067AC363d66E9EF2E007Fea85E33

# Base.dev project (meta tag + dashboard)
NEXT_PUBLIC_BASE_APP_ID=your-base-app-id

# Builder Code from base.dev → Settings → Builder Code (e.g. bc_…)
NEXT_PUBLIC_BUILDER_CODE=
# Optional: raw hex suffix instead of generating from code (advanced)
# NEXT_PUBLIC_BUILDER_CODE_SUFFIX=0x...

# Optional WalletConnect
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
