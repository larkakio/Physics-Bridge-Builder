# Base app id (dashboard → domain verification, matches <meta name="base:app_id" />)
NEXT_PUBLIC_BASE_APP_ID=69e47d6786272d70f28d7427

# Builder Code (dashboard → App → Builder Codes)
NEXT_PUBLIC_BUILDER_CODE=bc_46pp54c3
